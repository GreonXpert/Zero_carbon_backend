# =============================================================================
# Zero Carbon Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth / Security ───────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
FIELD_ENCRYPTION_KEY=64_char_hex_string_for_aes256_gcm

# ── Super Admin Seed ──────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your_super_admin_password

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_PROFILE_IMAGES_BUCKET=your-profile-images-bucket
S3_UPLOADS_BUCKET=your-uploads-bucket
S3_DOCUMENTS_BUCKET=your-documents-bucket

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# GreOn IQ — AI Analytics Assistant
# =============================================================================

# DEEPSEEK_API_KEY: Required for GreOn IQ to function.
# Obtain from https://platform.deepseek.com
# If not set, GreOn IQ will start with a warning and all AI generation
# endpoints will return a safe error. History viewing remains available.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DEEPSEEK_MODEL: DeepSeek model identifier.
# Default: deepseek-chat (maps to DeepSeek-V3 / DeepSeek-V3.2)
# To switch model: change this value and restart the server. No code change needed.
# Options: deepseek-chat | deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# DEEPSEEK_BASE_URL: Override only if using a self-hosted or proxied endpoint.
# Default: https://api.deepseek.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DEEPSEEK_TIMEOUT: Request timeout in milliseconds.
# Default: 30000 (30 seconds)
# DEEPSEEK_TIMEOUT=30000

# DEEPSEEK_MAX_RETRY: Number of retry attempts on transient failures.
# Default: 2
# DEEPSEEK_MAX_RETRY=2
